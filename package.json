{
  "name": "ch4c",
  "version": "0.4.4",
  "bin": {
    "ch4c": "./main.js"
  },
  "description": "Chrome HDMI for Channels DVR",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dravenst/CH4C.git"
  },
  "author": "dravenst",
  "keywords": [
    "channels",
    "dvr",
    "channelsdvr",
    "hdmi",
    "streaming",
    "puppeteer"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/dravenst/CH4C/issues"
  },
  "homepage": "https://github.com/dravenst/CH4C#readme",
  "dependencies": {
    "@novnc/novnc": "^1.6.0",
    "express": "^5.1.0",
    "node-fetch": "^2.7.0",
    "rebrowser-puppeteer-core": "^24.8.1",
    "selfsigned": "^5.5.0",
    "ws": "^8.18.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "globals": "^16.0.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "vendor/novnc/**/*",
      "vendor/winsw/WinSW-x64.exe",
      "ch4c-launcher.cs"
    ]
  },
  "scripts": {
    "postinstall": "node -e \"if(process.platform==='linux'){console.log('\\nWARNING: Linux detected. CH4C is primarily supported on Windows and macOS.\\n  The \\'ch4c service install\\' command is not available on Linux.\\n  You can still run CH4C manually with: ch4c\\n')}\"",
    "build": "pkg . --targets latest-win-x64 --output dist/ch4c.exe && pkg . --targets latest-macos-x64 --output dist/ch4c",
    "build:win": "pkg . --targets latest-win-x64 --output dist/ch4c.exe",
    "build:mac": "pkg . --targets latest-macos-x64 --output dist/ch4c"
  }
}
